    <!-- Additional ontology annotations -->
    <owl:AnnotationProperty rdf:about="#businessRule"/>
    <owl:AnnotationProperty rdf:about="#confidenceScore"/>

    <rdf:Description rdf:about="#Booking">
        <businessRule>A booking is recorded when Cisco accepts a valid order with committed value.</businessRule>
        <businessRule>Bookings are measured at order-line grain.</businessRule>
        <businessRule>For subscription and SaaS offers, booking amount equals TCV and ACV is annualized; documented as business rule annotation because arithmetic enforcement is outside OWL DL.</businessRule>
        <confidenceScore rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1.00</confidenceScore>
    </rdf:Description>

    <rdf:Description rdf:about="#Customer">
        <confidenceScore rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1.00</confidenceScore>
    </rdf:Description>

